            {
              "id": "SNYK-JAVA-COMFASTERXMLJACKSONCORE-450917",
              "shortDescription": {
                "text": "Critical severity - Deserialization of Untrusted Data vulnerability in com.fasterxml.jackson.core:jackson-databind"
