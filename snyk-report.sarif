              "id": "SNYK-JAVA-ORGYAML-3016888",
              "shortDescription": {
                "text": "Low severity - Stack-based Buffer Overflow vulnerability in org.yaml:snakeyaml"
              },
              "fullDescription": {
                "text": "(CVE-2022-38752) org.yaml:snakeyaml@1.17"
